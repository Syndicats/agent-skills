{
  "name": "@syndicats/agent-skills",
  "version": "2.0.0",
  "description": "Universal CLI for managing AI agent skills across 45+ agents. Install from Git repos, npm packages, and local directories.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "skills": "./dist/cli/index.js",
    "agent-skills": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:fast": "tsup src/cli/index.ts src/index.ts --format esm --dts --clean --outDir dist",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent-skills",
    "ai",
    "llm",
    "cursor",
    "claude-code",
    "github-copilot",
    "openai-codex",
    "skills",
    "marketplace",
    "private-git",
    "npm-packages",
    "bitbucket",
    "ssh",
    "enterprise",
    "skillsrc"
  ],
  "author": "Syndicats",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Syndicats/agent-skills.git"
  },
  "homepage": "https://github.com/Syndicats/agent-skills",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^10.4.5",
    "gray-matter": "^4.0.3",
    "inquirer": "^13.1.0",
    "ora": "^9.0.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4",
    "vitest": "^4.0.16"
  }
}